# 忽略 Python 自动生成的缓存文件
__pycache__/
*.py[cod]
*$py.class

# 忽略环境配置和开发工具的隐藏文件夹
.vscode/
.idea/
.env
venv/

# 忽略运动识别训练数据（PCAP 文件过大）
motion/motion/hello/
motion/motion/jump/
motion/motion/step/
motion/motion/walk/

# 忽略运动识别模型输出（临时文件）
motion/motion/outputs_motion_model*/
motion/motion/scapy/

# 忽略 data 目录下的大型 PCAP 文件（保留必要的测试数据可按需修改）
data/*.pcap
data/*.pcapng
data/api_runs/*.pcapng

# 忽略各检测模块的 API 运行输出数据（这些都是临时结果和大文件）
motion/motion/api_runs/
payload-detection/data/api_runs/
core/api_runs/
backend/api_runs/